---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout title="Contacto | Asesorías Borotto" description="Contáctanos para una consulta gratuita con Asesorías Borotto. Estamos aquí para ayudarte con tu contabilidad.">
  <Header />
  <main>
    <Hero
      title='Hablemos de tu <span class="accent">negocio</span>'
      subtitle="Agenda una consulta gratuita. Estoy aquí para ayudarte."
      compact={true}
      ctaPrimary={{ text: 'Ver Planes', href: '/planes' }}
      ctaSecondary={{ text: 'Sobre Mí', href: '/sobre-mi' }}
    />

    <section class="section">
      <div class="container">
        <div class="contact-grid">
          <!-- Formulario -->
          <div class="contact-form-wrapper reveal-left">
            <h2>Envíame un mensaje</h2>
            <p style="margin-bottom: var(--space-6);">Completa el formulario y te responderé a la brevedad.</p>

            <form id="contact-form" class="contact-form">
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="name">Nombre completo *</label>
                  <input type="text" id="name" name="name" class="form-input" required placeholder="Tu nombre" />
                </div>
                <div class="form-group">
                  <label class="form-label" for="email">Email *</label>
                  <input type="email" id="email" name="email" class="form-input" required placeholder="tu@email.com" />
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="phone">Teléfono</label>
                  <input type="tel" id="phone" name="phone" class="form-input" placeholder="+56 9 xxxx xxxx" />
                </div>
                <div class="form-group">
                  <label class="form-label" for="service">Servicio de interés</label>
                  <select id="service" name="service" class="form-select">
                    <option value="">Seleccionar...</option>
                    <option value="impuestos">Declaración de Impuestos</option>
                    <option value="contabilidad">Contabilidad Completa</option>
                    <option value="remuneraciones">Remuneraciones</option>
                    <option value="inicio-actividades">Inicio de Actividades</option>
                    <option value="asesoria">Asesoría Tributaria</option>
                    <option value="auditoria">Auditoría Financiera</option>
                    <option value="otro">Otro</option>
                  </select>
                </div>
              </div>
              <div class="form-group">
                <label class="form-label" for="message">Mensaje *</label>
                <textarea id="message" name="message" class="form-textarea" required placeholder="Cuéntame sobre tu negocio y cómo puedo ayudarte..."></textarea>
              </div>
              <button type="submit" class="btn btn-primary btn-lg w-full" id="submit-btn">
                Enviar Mensaje
              </button>
              <div id="form-status" class="form-status" style="display:none;"></div>
            </form>
          </div>

          <!-- Info de contacto -->
          <div class="contact-info reveal-right">
            <div class="card-glass info-card">
              <h3>Información de contacto</h3>
              <ul class="info-list">
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                  <div>
                    <strong>Email</strong>
                    <a href="mailto:contacto@asesoriasborotto.cl">contacto@asesoriasborotto.cl</a>
                  </div>
                </li>
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  <div>
                    <strong>Teléfono</strong>
                    <a href="tel:+56973764841">+56 9 7376 4841</a>
                  </div>
                </li>
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  <div>
                    <strong>Horario de atención</strong>
                    <span>Lunes a Viernes, 9:00 — 18:00</span>
                  </div>
                </li>
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  <div>
                    <strong>Ubicación</strong>
                    <span>Santiago, Chile</span>
                  </div>
                </li>
              </ul>
            </div>

            <div class="card-glass info-card" style="margin-top: var(--space-6); text-align: center;">
              <h3>¿Prefieres WhatsApp?</h3>
              <p style="margin: var(--space-3) 0 var(--space-4);">Escríbeme directamente y te respondo a la brevedad.</p>
              <a href="https://wa.me/56973764841?text=Hola!%20Me%20interesa%20conocer%20m%C3%A1s%20sobre%20tus%20servicios." target="_blank" rel="noopener" class="btn btn-primary" style="background: #25D366; border-color: #25D366;">
                Abrir WhatsApp
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <WhatsAppButton />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const status = document.getElementById('form-status') as HTMLDivElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Confirmación antes de enviar
    const confirm = await Swal.fire({
      title: '¿Enviar mensaje?',
      text: 'Revisa que tus datos estén correctos antes de enviar.',
      icon: 'question',
      showCancelButton: true,
      confirmButtonColor: '#c9a84c',
      cancelButtonColor: '#6b7280',
      confirmButtonText: 'Sí, enviar',
      cancelButtonText: 'Revisar',
    });

    if (!confirm.isConfirmed) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';
    status.style.display = 'none';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await fetch('/api/contacto', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await res.json();

      if (res.ok) {
        form.reset();
        await Swal.fire({
          title: '¡Mensaje enviado!',
          text: 'Te responderé a la brevedad. ¡Gracias por contactarme!',
          icon: 'success',
          confirmButtonColor: '#c9a84c',
        });
      } else {
        await Swal.fire({
          title: 'Error al enviar',
          text: result.error || 'Hubo un problema. Intenta de nuevo.',
          icon: 'error',
          confirmButtonColor: '#c9a84c',
        });
      }
    } catch {
      await Swal.fire({
        title: 'Error de conexión',
        text: 'No se pudo conectar al servidor. Intenta de nuevo más tarde.',
        icon: 'error',
        confirmButtonColor: '#c9a84c',
      });
    }

    submitBtn.disabled = false;
    submitBtn.textContent = 'Enviar Mensaje';
  });
</script>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }

  .form-status {
    padding: var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 500;
    margin-top: var(--space-2);
  }

  .form-status.success {
    background: rgba(16, 185, 129, 0.1);
    color: var(--color-success);
    border: 1px solid rgba(16, 185, 129, 0.2);
  }

  .form-status.error {
    background: rgba(239, 68, 68, 0.1);
    color: var(--color-error);
    border: 1px solid rgba(239, 68, 68, 0.2);
  }

  .info-card h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-5);
  }

  .info-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .info-list li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .info-list svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-accent);
  }

  .info-list strong {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 2px;
  }

  .info-list a,
  .info-list span {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .info-list a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
