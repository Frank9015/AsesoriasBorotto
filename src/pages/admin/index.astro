---
import Layout from '../../layouts/Layout.astro';
import { prisma } from '../../lib/prisma';

// Auth check básica via cookie
const authCookie = Astro.cookies.get('admin_auth')?.value;
if (authCookie !== (import.meta.env.ADMIN_PASSWORD || 'admin123')) {
  // Si no está autenticado, mostrar login
}
const isAuthenticated = authCookie === (import.meta.env.ADMIN_PASSWORD || 'admin123');

const totalPlans = await prisma.plan.count();
const totalServices = await prisma.service.count();
const totalTestimonials = await prisma.testimonial.count();
const totalMessages = await prisma.message.count();
const unreadMessages = await prisma.message.count({ where: { read: false } });
---

<Layout title="Panel Admin | Asesorías Borotto">
  {!isAuthenticated ? (
    <div class="login-wrapper">
      <div class="login-card">
        <div class="login-logo">
          <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" width="48" height="48">
            <rect width="32" height="32" rx="8" fill="var(--color-primary)"/>
            <path d="M8 24V8h4l4 10 4-10h4v16h-3V13l-3.5 9h-3L11 13v11H8z" fill="var(--color-accent)"/>
          </svg>
        </div>
        <h1>Panel Admin</h1>
        <p>Ingresa la contraseña para acceder</p>
        <form id="login-form">
          <div class="form-group">
            <input type="password" id="admin-password" class="form-input" placeholder="Contraseña" required autofocus />
          </div>
          <button type="submit" class="btn btn-primary w-full">Entrar</button>
          <p id="login-error" class="login-error" style="display:none;">Contraseña incorrecta</p>
        </form>
      </div>
    </div>
  ) : (
    <div class="admin-layout">
      <aside class="admin-sidebar">
        <div class="sidebar-logo">
          <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" width="32" height="32">
            <rect width="32" height="32" rx="8" fill="var(--color-accent)"/>
            <path d="M8 24V8h4l4 10 4-10h4v16h-3V13l-3.5 9h-3L11 13v11H8z" fill="var(--color-primary)"/>
          </svg>
          <span>Admin</span>
        </div>
        <nav class="sidebar-nav">
          <a href="/admin" class="sidebar-link active">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Dashboard
          </a>
          <a href="/admin/planes" class="sidebar-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            Planes
          </a>
          <a href="/admin/servicios" class="sidebar-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            Servicios
          </a>
          <a href="/admin/testimonios" class="sidebar-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Testimonios
          </a>
          <a href="/admin/mensajes" class="sidebar-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Mensajes {unreadMessages > 0 && <span class="badge-count">{unreadMessages}</span>}
          </a>
        </nav>
        <div class="sidebar-footer">
          <a href="/" class="sidebar-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            Ver Sitio
          </a>
          <button id="logout-btn" class="sidebar-link" style="border:none;background:none;width:100%;cursor:pointer;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Cerrar Sesión
          </button>
        </div>
      </aside>

      <main class="admin-main">
        <div class="admin-header">
          <h1>Dashboard</h1>
          <p>Resumen general del sitio</p>
        </div>

        <div class="stats-cards">
          <div class="stat-card">
            <div class="stat-card-icon" style="background: rgba(201,168,76,0.1); color: var(--color-accent);">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <div>
              <span class="stat-card-num">{totalPlans}</span>
              <span class="stat-card-label">Planes</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-card-icon" style="background: rgba(45,74,122,0.1); color: var(--color-primary-light);">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </div>
            <div>
              <span class="stat-card-num">{totalServices}</span>
              <span class="stat-card-label">Servicios</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-card-icon" style="background: rgba(16,185,129,0.1); color: var(--color-success);">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <div>
              <span class="stat-card-num">{totalTestimonials}</span>
              <span class="stat-card-label">Testimonios</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-card-icon" style="background: rgba(239,68,68,0.1); color: var(--color-error);">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <span class="stat-card-num">{totalMessages}</span>
              <span class="stat-card-label">Mensajes {unreadMessages > 0 && `(${unreadMessages} nuevos)`}</span>
            </div>
          </div>
        </div>

        <div class="quick-links">
          <h2>Acciones Rápidas</h2>
          <div class="quick-grid">
            <a href="/admin/planes" class="quick-card">
              <strong>Gestionar Planes</strong>
              <p>Agrega, edita o elimina planes de precios</p>
            </a>
            <a href="/admin/servicios" class="quick-card">
              <strong>Gestionar Servicios</strong>
              <p>Administra los servicios que ofreces</p>
            </a>
            <a href="/admin/testimonios" class="quick-card">
              <strong>Gestionar Testimonios</strong>
              <p>Administra las reseñas de clientes</p>
            </a>
            <a href="/admin/mensajes" class="quick-card">
              <strong>Ver Mensajes</strong>
              <p>Revisa los mensajes del formulario de contacto</p>
            </a>
          </div>
        </div>
      </main>
    </div>
  )}
</Layout>

<script>
  // Login
  const loginForm = document.getElementById('login-form') as HTMLFormElement | null;
  loginForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const pw = (document.getElementById('admin-password') as HTMLInputElement).value;
    document.cookie = `admin_auth=${pw}; path=/; SameSite=Strict`;
    window.location.reload();
  });

  // Logout con SweetAlert2
  document.getElementById('logout-btn')?.addEventListener('click', () => {
    Swal.fire({
      title: '¿Cerrar sesión?',
      text: 'Tendrás que volver a ingresar la contraseña para acceder.',
      icon: 'question',
      showCancelButton: true,
      confirmButtonColor: '#c9a84c',
      cancelButtonColor: '#6b7280',
      confirmButtonText: 'Sí, cerrar sesión',
      cancelButtonText: 'Cancelar',
    }).then((result: any) => {
      if (result.isConfirmed) {
        document.cookie = 'admin_auth=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT';
        window.location.href = '/admin';
      }
    });
  });
</script>

<style>
  /* Login */
  .login-wrapper {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-alt);
  }

  .login-card {
    background: var(--color-surface);
    padding: var(--space-10);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
    width: 100%;
    max-width: 400px;
    text-align: center;
  }

  .login-logo { margin-bottom: var(--space-6); }
  .login-card h1 { font-size: var(--text-2xl); margin-bottom: var(--space-2); }
  .login-card > p { margin-bottom: var(--space-6); }
  .login-card form { display: flex; flex-direction: column; gap: var(--space-4); }
  .login-error { color: var(--color-error); font-size: var(--text-sm); margin-top: var(--space-2); }

  /* Admin Layout */
  .admin-layout {
    display: flex;
    min-height: 100vh;
  }

  /* Sidebar */
  .admin-sidebar {
    width: 250px;
    background: var(--color-primary);
    color: white;
    display: flex;
    flex-direction: column;
    padding: var(--space-6);
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 100;
  }

  .sidebar-logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    flex: 1;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    color: rgba(255,255,255,0.7);
    font-size: var(--text-sm);
    font-weight: 500;
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  .sidebar-link:hover, .sidebar-link.active {
    background: rgba(255,255,255,0.1);
    color: white;
  }

  .sidebar-link.active { background: rgba(201,168,76,0.2); color: var(--color-accent); }

  .badge-count {
    background: var(--color-error);
    color: white;
    font-size: 11px;
    padding: 1px 6px;
    border-radius: var(--radius-full);
    margin-left: auto;
  }

  .sidebar-footer {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  /* Main Content */
  .admin-main {
    flex: 1;
    margin-left: 250px;
    padding: var(--space-8);
    background: var(--color-bg);
  }

  .admin-header {
    margin-bottom: var(--space-8);
  }

  .admin-header h1 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-1);
  }

  .admin-header p {
    color: var(--color-text-muted);
  }

  /* Stats Cards */
  .stats-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
    margin-bottom: var(--space-10);
  }

  .stat-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    align-items: center;
    gap: var(--space-4);
    border: 1px solid var(--color-border-light);
  }

  .stat-card-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stat-card-num {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text);
  }

  .stat-card-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* Quick Links */
  .quick-links h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }

  .quick-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  .quick-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .quick-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
  }

  .quick-card strong {
    display: block;
    color: var(--color-primary);
    margin-bottom: var(--space-1);
  }

  .quick-card p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  @media (max-width: 1024px) {
    .stats-cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .admin-sidebar { display: none; }
    .admin-main { margin-left: 0; }
    .stats-cards, .quick-grid { grid-template-columns: 1fr; }
  }
</style>
