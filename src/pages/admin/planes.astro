---
import Layout from '../../layouts/Layout.astro';
import { prisma } from '../../lib/prisma';

const authCookie = Astro.cookies.get('admin_auth')?.value;
if (authCookie !== (import.meta.env.ADMIN_PASSWORD || 'admin123')) {
  return Astro.redirect('/admin');
}

const unreadMessages = await prisma.message.count({ where: { read: false } });
const plans = await prisma.plan.findMany({ orderBy: { order: 'asc' } });
---

<Layout title="Planes | Admin">
  <div class="admin-layout">
    <aside class="admin-sidebar">
      <div class="sidebar-logo">
        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" width="32" height="32"><rect width="32" height="32" rx="8" fill="var(--color-accent)"/><path d="M8 24V8h4l4 10 4-10h4v16h-3V13l-3.5 9h-3L11 13v11H8z" fill="var(--color-primary)"/></svg>
        <span>Admin</span>
      </div>
      <nav class="sidebar-nav">
        <a href="/admin" class="sidebar-link">Dashboard</a>
        <a href="/admin/planes" class="sidebar-link active">Planes</a>
        <a href="/admin/servicios" class="sidebar-link">Servicios</a>
        <a href="/admin/testimonios" class="sidebar-link">Testimonios</a>
        <a href="/admin/mensajes" class="sidebar-link">Mensajes {unreadMessages > 0 && <span class="badge-count">{unreadMessages}</span>}</a>
      </nav>
      <div class="sidebar-footer">
        <a href="/" class="sidebar-link">Ver Sitio</a>
      </div>
    </aside>

    <main class="admin-main">
      <div class="admin-header">
        <h1>Gestión de Planes</h1>
        <button class="btn btn-primary" id="add-btn">+ Agregar Plan</button>
      </div>

      <!-- Modal de formulario -->
      <div class="modal-overlay" id="modal" style="display:none;">
        <div class="modal-card">
          <h2 id="modal-title">Nuevo Plan</h2>
          <form id="plan-form">
            <input type="hidden" id="plan-id" />
            <div class="form-group">
              <label class="form-label">Nombre</label>
              <input type="text" id="plan-name" class="form-input" required placeholder="Ej: Plan Básico" />
            </div>
            <div class="form-group">
              <label class="form-label">Precio</label>
              <input type="text" id="plan-price" class="form-input" required placeholder="Ej: Desde $50.000" />
            </div>
            <div class="form-group">
              <label class="form-label">Descripción</label>
              <textarea id="plan-desc" class="form-textarea" required placeholder="Descripción del plan"></textarea>
            </div>
            <div class="form-group">
              <label class="form-label">Características (una por línea)</label>
              <textarea id="plan-features" class="form-textarea" placeholder="Declaración F-29&#10;Asesoría online&#10;Soporte WhatsApp"></textarea>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Orden</label>
                <input type="number" id="plan-order" class="form-input" value="0" />
              </div>
              <div class="form-group" style="display:flex;align-items:end;">
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
                  <input type="checkbox" id="plan-highlighted" />
                  <span class="form-label" style="margin:0;">Destacado</span>
                </label>
              </div>
            </div>
            <div class="modal-actions">
              <button type="button" class="btn btn-secondary" id="cancel-btn">Cancelar</button>
              <button type="submit" class="btn btn-primary">Guardar</button>
            </div>
          </form>
        </div>
      </div>

      <!-- Lista de planes -->
      <div class="admin-table-wrapper">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Orden</th>
              <th>Nombre</th>
              <th>Precio</th>
              <th>Destacado</th>
              <th>Features</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody id="plans-body">
            {plans.map((plan) => (
              <tr data-id={plan.id}>
                <td>{plan.order}</td>
                <td><strong>{plan.name}</strong></td>
                <td>{plan.price}</td>
                <td>{plan.highlighted ? '⭐' : '—'}</td>
                <td>{plan.features.length} items</td>
                <td class="actions-cell">
                  <button class="btn-sm btn-edit" data-plan={JSON.stringify(plan)}>Editar</button>
                  <button class="btn-sm btn-delete" data-id={plan.id}>Eliminar</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
        {plans.length === 0 && <p class="empty-msg">No hay planes creados aún.</p>}
      </div>
    </main>
  </div>
</Layout>

<script>
  const modal = document.getElementById('modal')!;
  const form = document.getElementById('plan-form') as HTMLFormElement;
  const modalTitle = document.getElementById('modal-title')!;
  const authToken = document.cookie.split(';').find(c => c.trim().startsWith('admin_auth='))?.split('=')[1] || '';

  document.getElementById('add-btn')!.addEventListener('click', () => {
    modalTitle.textContent = 'Nuevo Plan';
    form.reset();
    (document.getElementById('plan-id') as HTMLInputElement).value = '';
    modal.style.display = 'flex';
  });

  document.getElementById('cancel-btn')!.addEventListener('click', () => {
    modal.style.display = 'none';
  });

  // Edit buttons
  document.querySelectorAll('.btn-edit').forEach(btn => {
    btn.addEventListener('click', () => {
      const plan = JSON.parse((btn as HTMLElement).dataset.plan!);
      modalTitle.textContent = 'Editar Plan';
      (document.getElementById('plan-id') as HTMLInputElement).value = plan.id;
      (document.getElementById('plan-name') as HTMLInputElement).value = plan.name;
      (document.getElementById('plan-price') as HTMLInputElement).value = plan.price;
      (document.getElementById('plan-desc') as HTMLTextAreaElement).value = plan.description;
      (document.getElementById('plan-features') as HTMLTextAreaElement).value = plan.features.join('\n');
      (document.getElementById('plan-order') as HTMLInputElement).value = plan.order;
      (document.getElementById('plan-highlighted') as HTMLInputElement).checked = plan.highlighted;
      modal.style.display = 'flex';
    });
  });

  // Delete
  document.querySelectorAll('.btn-delete').forEach(btn => {
    btn.addEventListener('click', async () => {
      const result = await Swal.fire({
        title: '¿Eliminar este plan?',
        text: 'Esta acción no se puede deshacer.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444',
        cancelButtonColor: '#6b7280',
        confirmButtonText: 'Sí, eliminar',
        cancelButtonText: 'Cancelar',
      });
      if (!result.isConfirmed) return;
      const id = Number((btn as HTMLElement).dataset.id);
      const res = await fetch('/api/planes', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${authToken}` },
        body: JSON.stringify({ id }),
      });
      if (res.ok) {
        await Swal.fire({ title: '¡Eliminado!', text: 'El plan fue eliminado correctamente.', icon: 'success', confirmButtonColor: '#c9a84c', timer: 1500, showConfirmButton: false });
      } else {
        await Swal.fire({ title: 'Error', text: 'No se pudo eliminar el plan.', icon: 'error', confirmButtonColor: '#c9a84c' });
      }
      window.location.reload();
    });
  });

  // Submit
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = (document.getElementById('plan-id') as HTMLInputElement).value;
    const data = {
      id: id ? Number(id) : undefined,
      name: (document.getElementById('plan-name') as HTMLInputElement).value,
      price: (document.getElementById('plan-price') as HTMLInputElement).value,
      description: (document.getElementById('plan-desc') as HTMLTextAreaElement).value,
      features: (document.getElementById('plan-features') as HTMLTextAreaElement).value.split('\n').filter(f => f.trim()),
      order: Number((document.getElementById('plan-order') as HTMLInputElement).value),
      highlighted: (document.getElementById('plan-highlighted') as HTMLInputElement).checked,
    };
    const res = await fetch('/api/planes', {
      method: id ? 'PUT' : 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${authToken}` },
      body: JSON.stringify(data),
    });
    if (res.ok) {
      await Swal.fire({ title: id ? '¡Actualizado!' : '¡Creado!', text: `Plan ${id ? 'actualizado' : 'creado'} correctamente.`, icon: 'success', confirmButtonColor: '#c9a84c', timer: 1500, showConfirmButton: false });
    } else {
      await Swal.fire({ title: 'Error', text: 'Hubo un problema al guardar.', icon: 'error', confirmButtonColor: '#c9a84c' });
    }
    window.location.reload();
  });
</script>

<style>
  .admin-layout { display: flex; min-height: 100vh; }
  .admin-sidebar { width: 250px; background: var(--color-primary); color: white; display: flex; flex-direction: column; padding: var(--space-6); position: fixed; top: 0; bottom: 0; left: 0; }
  .sidebar-logo { display: flex; align-items: center; gap: var(--space-3); font-family: var(--font-heading); font-size: var(--text-xl); font-weight: 700; margin-bottom: var(--space-8); padding-bottom: var(--space-6); border-bottom: 1px solid rgba(255,255,255,0.1); }
  .sidebar-nav { display: flex; flex-direction: column; gap: var(--space-1); flex: 1; }
  .sidebar-link { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-3) var(--space-4); color: rgba(255,255,255,0.7); font-size: var(--text-sm); font-weight: 500; border-radius: var(--radius-md); transition: all var(--transition-fast); text-decoration: none; }
  .sidebar-link:hover, .sidebar-link.active { background: rgba(255,255,255,0.1); color: white; }
  .sidebar-link.active { background: rgba(201,168,76,0.2); color: var(--color-accent); }
  .badge-count { background: var(--color-error); color: white; font-size: 11px; padding: 1px 6px; border-radius: var(--radius-full); margin-left: auto; }
  .sidebar-footer { border-top: 1px solid rgba(255,255,255,0.1); padding-top: var(--space-4); }
  .admin-main { flex: 1; margin-left: 250px; padding: var(--space-8); background: var(--color-bg); }
  .admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-8); }
  .admin-header h1 { font-size: var(--text-3xl); }

  .admin-table-wrapper { background: var(--color-surface); border-radius: var(--radius-lg); border: 1px solid var(--color-border-light); overflow: hidden; }
  .admin-table { width: 100%; border-collapse: collapse; }
  .admin-table th { text-align: left; padding: var(--space-4); font-size: var(--text-sm); font-weight: 600; color: var(--color-text-muted); border-bottom: 1px solid var(--color-border-light); background: var(--color-bg-alt); }
  .admin-table td { padding: var(--space-4); font-size: var(--text-sm); border-bottom: 1px solid var(--color-border-light); }
  .actions-cell { display: flex; gap: var(--space-2); }
  .btn-sm { padding: var(--space-1) var(--space-3); font-size: var(--text-xs); border: 1px solid var(--color-border); background: var(--color-surface); border-radius: var(--radius-sm); cursor: pointer; transition: all var(--transition-fast); }
  .btn-sm:hover { background: var(--color-bg-alt); }
  .btn-delete:hover { background: rgba(239,68,68,0.1); color: var(--color-error); border-color: var(--color-error); }
  .empty-msg { text-align: center; padding: var(--space-10); color: var(--color-text-muted); }

  .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; }
  .modal-card { background: var(--color-surface); border-radius: var(--radius-xl); padding: var(--space-8); width: 100%; max-width: 550px; max-height: 90vh; overflow-y: auto; }
  .modal-card h2 { font-size: var(--text-2xl); margin-bottom: var(--space-6); }
  .modal-card form { display: flex; flex-direction: column; gap: var(--space-4); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); }
  .modal-actions { display: flex; gap: var(--space-3); justify-content: flex-end; margin-top: var(--space-4); }

  @media (max-width: 768px) {
    .admin-sidebar { display: none; }
    .admin-main { margin-left: 0; }
  }
</style>
