---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import PlanCard from '../components/PlanCard.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { prisma } from '../lib/prisma';

// Fetch data from database
const plans = await prisma.plan.findMany({ orderBy: { order: 'asc' } });
const services = await prisma.service.findMany({ orderBy: { order: 'asc' } });
const testimonials = await prisma.testimonial.findMany({ where: { visible: true }, take: 3 });

// Iconos SVG inline para servicios (Lucide icons)
const iconMap: Record<string, string> = {
  'file-text': '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>',
  'calculator': '<rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="16" y1="14" x2="16" y2="18"/><line x1="8" y1="10" x2="8" y2="10.01"/><line x1="12" y1="10" x2="12" y2="10.01"/><line x1="16" y1="10" x2="16" y2="10.01"/><line x1="8" y1="14" x2="8" y2="14.01"/><line x1="12" y1="14" x2="12" y2="14.01"/><line x1="8" y1="18" x2="8" y2="18.01"/><line x1="12" y1="18" x2="12" y2="18.01"/>',
  'users': '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  'rocket': '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',
  'shield-check': '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>',
  'search': '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>',
};
---

<Layout title="Asesorías Borotto | Servicios Contables Profesionales en Chile">
  <Header />

  <main>
    <Hero
      title='Tu contabilidad en <span class="accent">buenas manos</span>'
      subtitle="Asesorías contables, tributarias y de auditoría profesional para emprendedores y pymes en Chile."
      ctaPrimary={{ text: 'Ver Planes', href: '/planes' }}
      ctaSecondary={{ text: 'Conocer Más', href: '/sobre-mi' }}
    />

    <!-- Stats -->
    <section class="stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item reveal delay-1">
            <span class="stat-number">5+</span>
            <span class="stat-label">Años de experiencia</span>
          </div>
          <div class="stat-item reveal delay-2">
            <span class="stat-number">50+</span>
            <span class="stat-label">Clientes satisfechos</span>
          </div>
          <div class="stat-item reveal delay-3">
            <span class="stat-number">100%</span>
            <span class="stat-label">Compromiso</span>
          </div>
          <div class="stat-item reveal delay-4">
            <span class="stat-number">24/7</span>
            <span class="stat-label">Disponibilidad</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Servicios Preview -->
    <section class="section" id="services-preview">
      <div class="container">
        <div class="section-header">
          <span class="section-label">Servicios</span>
          <h2>Soluciones contables a tu medida</h2>
          <p>Ofrezco una gama completa de servicios contables, tributarios y de auditoría para que te enfoques en hacer crecer tu negocio.</p>
        </div>

        <div class="services-grid">
          {services.slice(0, 3).map((service, i) => (
            <div class={`service-card reveal delay-${Math.min(i + 1, 3)}`}>
              <div class="service-header">
                <div class="service-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <Fragment set:html={iconMap[service.icon] || iconMap['file-text']} />
                  </svg>
                </div>
                {service.price && <span class="service-price-badge">{service.price}</span>}
              </div>
              <h3 class="service-name">{service.name}</h3>
              {service.description && service.description.trim() !== '' && (
                <p class="service-desc" set:html={service.description.replace(/\n/g, '<br/>')}></p>
              )}
              
              {service.features && service.features.length > 0 && (
                <ul class="service-features">
                  {service.features.map((feature: string) => (
                    <li>
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="check-icon">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
              )}
              
              <a href={`/contacto?servicio=${encodeURIComponent(service.name)}`} class="btn btn-primary text-center" style="margin-top: auto; width: 100%;">
                Solicitar
              </a>
            </div>
          ))}
        </div>

        <div class="text-center mt-8 reveal">
          <a href="/servicios" class="btn btn-secondary">Ver Todos los Servicios</a>
        </div>
      </div>
    </section>

    <!-- Planes Preview -->
    <section class="section plans-section" id="plans-preview">
      <div class="container">
        <div class="section-header">
          <span class="section-label">Planes</span>
          <h2>Planes pensados para ti</h2>
          <p>Elige el plan que mejor se adapte a las necesidades de tu negocio. Todos incluyen atención personalizada.</p>
        </div>

        <div class="plans-grid">
          {plans.map((plan, i) => (
            <div class={`reveal delay-${i + 1}`}>
              <PlanCard
                name={plan.name}
                price={plan.price}
                description={plan.description}
                features={plan.features}
                highlighted={plan.highlighted}
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonios -->
    {testimonials.length > 0 && (
      <section class="section" id="testimonials-preview">
        <div class="container">
          <div class="section-header">
            <span class="section-label">Testimonios</span>
            <h2>Lo que dicen mis clientes</h2>
            <p>La confianza de mis clientes es mi mayor orgullo. Conoce sus experiencias.</p>
          </div>

          <div class="testimonials-grid">
            {testimonials.map((t, i) => (
              <div class={`card testimonial-card reveal delay-${i + 1}`}>
                <div class="testimonial-quote">"</div>
                <p class="testimonial-text">{t.text}</p>
                <div class="testimonial-author">
                  <div class="testimonial-avatar">
                    {t.name.charAt(0)}
                  </div>
                  <div>
                    <strong class="testimonial-name">{t.name}</strong>
                    {t.role && t.company && (
                      <span class="testimonial-role">{t.role} — {t.company}</span>
                    )}
                  </div>
                </div>
                <div class="testimonial-stars">
                  {Array.from({ length: t.rating }).map(() => (
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="var(--color-accent)" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  ))}
                </div>
              </div>
            ))}
          </div>

          <div class="text-center mt-8 reveal">
            <a href="/testimonios" class="btn btn-secondary">Ver Más Testimonios</a>
          </div>
        </div>
      </section>
    )}

    <!-- CTA Final -->
    <section class="cta-section reveal">
      <div class="container">
        <div class="cta-card">
          <h2>¿Lista para ordenar tus finanzas?</h2>
          <p>Agenda una consulta gratuita y descubre cómo puedo ayudarte a llevar tu contabilidad con tranquilidad.</p>
          <div class="hero-ctas" style="justify-content: center; margin-top: var(--space-8);">
            <a href="/contacto" class="btn btn-primary btn-lg">Agendar Consulta Gratis</a>
            <a href="/planes" class="btn btn-white btn-lg">Ver Planes</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppButton />
</Layout>

<style>
  /* Stats */
  .stats-section {
    padding: var(--space-12) 0;
    background: var(--color-primary);
    margin-top: -1px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-8);
    text-align: center;
  }

  .stat-item {
    color: white;
  }

  .stat-number {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 800;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }

  .stat-label {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.7);
  }

  /* Services Grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .service-card {
    display: flex;
    flex-direction: column;
    background: var(--color-primary);
    color: white;
    border: 1px solid rgba(201, 168, 76, 0.3);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    transition: all var(--transition-base);
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    position: relative;
    overflow: hidden;
    text-align: left;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--color-accent);
  }

  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.25);
    border-color: var(--color-accent);
  }

  .service-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    width: 100%;
    margin-bottom: var(--space-4);
  }

  .service-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(201, 168, 76, 0.15);
    color: var(--color-accent);
    border-radius: var(--radius-lg);
    margin: 0;
  }

  .service-name {
    font-size: var(--text-2xl); 
    font-family: var(--font-heading);
    margin-bottom: var(--space-2);
    color: white;
  }

  .service-price-badge {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-accent);
    background: rgba(201, 168, 76, 0.1);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    border: 1px solid rgba(201, 168, 76, 0.3);
    white-space: nowrap;
    margin-bottom: 0;
  }

  .service-desc {
    font-size: var(--text-sm); 
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }

  .service-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .service-features li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.9);
    line-height: 1.5;
  }

  .check-icon {
    flex-shrink: 0;
    color: var(--color-accent);
    margin-top: 2px;
  }

  /* Plans Grid */
  .plans-section {
    background: var(--color-bg-alt);
  }

  .plans-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-6);
  }

  .plans-grid > div {
    flex: 1 1 calc(33.333% - var(--space-6));
    max-width: calc(33.333% - var(--space-6));
    min-width: 300px;
    display: flex;
  }

  .plans-grid > div > :global(*) {
    width: 100%;
    height: 100%;
  }

  /* Testimonials Grid */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .testimonial-card {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .testimonial-quote {
    font-family: var(--font-heading);
    font-size: 4rem;
    line-height: 1;
    color: var(--color-accent);
    opacity: 0.3;
    position: absolute;
    top: var(--space-4);
    left: var(--space-6);
  }

  .testimonial-text {
    font-size: var(--text-base);
    color: var(--color-text);
    font-style: italic;
    line-height: 1.7;
    margin-bottom: var(--space-6);
    padding-top: var(--space-6);
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: auto;
  }

  .testimonial-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-lg);
  }

  .testimonial-name {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .testimonial-role {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .testimonial-stars {
    display: flex;
    gap: 2px;
    margin-top: var(--space-3);
  }

  /* CTA Section */
  .cta-section {
    padding: var(--space-8) 0 var(--space-16);
  }

  .cta-card {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    color: white;
    text-align: center;
    padding: var(--space-16) var(--space-8);
    border-radius: var(--radius-xl);
    position: relative;
    overflow: hidden;
  }

  .cta-card::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(201, 168, 76, 0.15), transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .cta-card h2 {
    color: white;
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
    position: relative;
  }

  .cta-card p {
    color: rgba(255, 255, 255, 0.8);
    font-size: var(--text-lg);
    max-width: 600px;
    margin-inline: auto;
    position: relative;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .services-grid,
    .testimonials-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .plans-grid > div {
      flex: 1 1 calc(50% - var(--space-6));
      max-width: calc(50% - var(--space-6));
    }
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }
  }

  @media (max-width: 640px) {
    .services-grid,
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
    .plans-grid > div {
      flex: 1 1 100%;
      max-width: 100%;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
