---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { prisma } from '../lib/prisma';

const services = await prisma.service.findMany({ orderBy: { order: 'asc' } });

const iconMap: Record<string, string> = {
  'file-text': '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>',
  'calculator': '<rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="16" y1="14" x2="16" y2="18"/><line x1="8" y1="10" x2="8" y2="10.01"/><line x1="12" y1="10" x2="12" y2="10.01"/><line x1="16" y1="10" x2="16" y2="10.01"/><line x1="8" y1="14" x2="8" y2="14.01"/><line x1="12" y1="14" x2="12" y2="14.01"/><line x1="8" y1="18" x2="8" y2="18.01"/><line x1="12" y1="18" x2="12" y2="18.01"/>',
  'users': '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  'rocket': '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',
  'shield-check': '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>',
  'search': '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>',
  'folder': '<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>',
  'briefcase': '<rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>',
  'trending-up': '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>',
  'bar-chart': '<line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/>',
  'map-pin': '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
  'palette': '<circle cx="13.5" cy="6.5" r=".5"/><circle cx="17.5" cy="10.5" r=".5"/><circle cx="8.5" cy="7.5" r=".5"/><circle cx="6.5" cy="12.5" r=".5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.46 2 12 2z"/>'
};

const steps = [
  { num: '01', title: 'Conversemos', desc: 'Cuéntame sobre tu negocio y tus necesidades contables. Agendemos una llamada o reunión.' },
  { num: '02', title: 'Plan personalizado', desc: 'Diseño un plan de trabajo adaptado a tu empresa, con plazos y entregables claros.' },
  { num: '03', title: 'Manos a la obra', desc: 'Me encargo de tu contabilidad mientras tú te enfocas en hacer crecer tu negocio.' },
  { num: '04', title: 'Seguimiento continuo', desc: 'Recibes informes periódicos y asesoría constante para tomar las mejores decisiones.' },
];
---

<Layout title="Servicios | Asesorías Borotto" description="Servicios de contabilidad, declaración de impuestos, remuneraciones, asesoría tributaria y auditoría financiera.">
  <Header />
  <main>
    <Hero
      title='Servicios <span class="accent">profesionales</span>'
      subtitle="Soluciones contables integrales para emprendedores y pymes. Tu tranquilidad financiera es mi prioridad."
      compact={true}
      ctaPrimary={{ text: 'Ver Planes', href: '/planes' }}
      ctaSecondary={{ text: 'Contactar', href: '/contacto' }}
    />

    <!-- Services Grid -->
    <section class="section">
      <div class="container">
        <div class="services-detail-grid">
          {services.map((service, i) => (
            <div class={`service-detail-card reveal delay-${Math.min(i + 1, 6)}`}>
              <div class="service-detail-header">
                <div class="service-detail-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <Fragment set:html={iconMap[service.icon] || iconMap['file-text']} />
                  </svg>
                </div>
                {service.price && <span class="service-price-badge">{service.price}</span>}
              </div>
              <h3 class="service-name">{service.name}</h3>
              {service.description && service.description.trim() !== '' && (
                <p class="service-desc" set:html={service.description.replace(/\n/g, '<br/>')}></p>
              )}
              
              {service.features && service.features.length > 0 && (
                <ul class="service-features">
                  {service.features.map((feature) => (
                    <li>
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="check-icon">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
              )}

              <a href={`/contacto?servicio=${encodeURIComponent(service.name)}`} class="btn btn-primary w-full text-center" style="margin-top: auto;">
                Solicitar
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="section process-section">
      <div class="container">
        <div class="section-header">
          <span class="section-label">Proceso</span>
          <h2>¿Cómo trabajamos juntos?</h2>
          <p>Un proceso simple y transparente para que te sientas acompañado en cada paso.</p>
        </div>
        <div class="process-grid">
          {steps.map((step, i) => (
            <div class={`process-step reveal delay-${i + 1}`}>
              <div class="process-num">{step.num}</div>
              <h3>{step.title}</h3>
              <p>{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <WhatsAppButton />
</Layout>

<style>
  .services-detail-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .service-detail-card {
    display: flex;
    flex-direction: column;
    background: var(--color-primary);
    color: white;
    border: 1px solid rgba(201, 168, 76, 0.3);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    transition: all var(--transition-base);
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    position: relative;
    overflow: hidden;
  }

  .service-detail-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--color-accent);
  }

  .service-detail-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.25);
    border-color: var(--color-accent);
  }

  .service-detail-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    width: 100%;
    margin-bottom: var(--space-4);
  }

  .service-detail-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(201, 168, 76, 0.15);
    color: var(--color-accent);
    border-radius: var(--radius-lg);
  }

  .service-price-badge {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-accent);
    background: rgba(201, 168, 76, 0.1);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    border: 1px solid rgba(201, 168, 76, 0.3);
    white-space: nowrap;
  }

  .service-name { 
    font-size: var(--text-2xl); 
    font-family: var(--font-heading);
    margin-bottom: var(--space-2);
    color: white;
  }
  
  .service-desc { 
    font-size: var(--text-sm); 
    color: rgba(255,255,255,0.7);
    margin-bottom: var(--space-6);
    line-height: 1.6;
  }

  .service-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .service-features li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.9);
    line-height: 1.5;
  }

  .check-icon {
    flex-shrink: 0;
    color: var(--color-accent);
    margin-top: 2px;
  }

  .w-full {
    width: 100%;
  }
  
  .text-center {
    text-align: center;
  }

  .process-section { background: var(--color-bg-alt); }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }

  .process-step { text-align: center; }

  .process-num {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 800;
    color: var(--color-accent);
    opacity: 0.5;
    margin-bottom: var(--space-3);
  }

  .process-step h3 { font-size: var(--text-lg); margin-bottom: var(--space-2); }
  .process-step p { font-size: var(--text-sm); }

  @media (max-width: 1024px) {
    .services-detail-grid { grid-template-columns: repeat(2, 1fr); }
    .process-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .services-detail-grid, .process-grid { grid-template-columns: 1fr; }
  }
</style>
