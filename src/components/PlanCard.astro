---
interface Props {
  name: string;
  price: string;
  description: string;
  features: string[];
  highlighted?: boolean;
}

const { name, price, description, features, highlighted = false } = Astro.props;
---

<div class:list={['plan-card', { highlighted }]}>
  {highlighted && <span class="badge badge-accent plan-badge">Popular</span>}
  <h3 class="plan-name">{name}</h3>
  <p class="plan-price">{price}</p>
  <p class="plan-desc">{description}</p>
  
  <ul class="plan-features">
    {features.map((feature) => {
      const isSub = feature.trim().startsWith('•');
      const cleanText = isSub ? feature.replace(/^•\s*/, '') : feature;
      return (
        <li class={isSub ? 'sub-feature' : ''}>
          {!isSub ? (
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          ) : (
            <span class="bullet-dot">•</span>
          )}
          <span>{cleanText}</span>
        </li>
      );
    })}
  </ul>

  <a href="/contacto" class:list={['btn', 'w-full', highlighted ? 'btn-primary' : 'btn-secondary']} style="text-align:center; margin-top: auto;">
    Solicitar
  </a>
</div>

<style>
  .plan-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1.5px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    transition: all var(--transition-base);
  }

  .plan-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-xl);
  }

  .plan-card.highlighted {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-glow);
    transform: scale(1.03);
  }

  .plan-card.highlighted:hover {
    transform: scale(1.03) translateY(-6px);
  }

  .plan-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
  }

  .plan-name {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }

  .plan-price {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 800;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .plan-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
    line-height: 1.6;
  }

  .plan-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .plan-features li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.5;
  }

  .plan-features li.sub-feature {
    padding-left: var(--space-5);
    color: var(--color-text-muted);
  }

  .plan-features svg {
    flex-shrink: 0;
    color: var(--color-success);
    margin-top: 0.15rem;
  }

  .bullet-dot {
    color: var(--color-accent);
    font-weight: bold;
    font-size: 1.2rem;
    line-height: 1;
    margin-right: var(--space-1);
    flex-shrink: 0;
  }
</style>
